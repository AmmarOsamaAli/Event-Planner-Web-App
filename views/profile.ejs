<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="icon" type="image/svg+xml" href="/images/logos/icon.svg">
    <title>My Profile</title>
</head>

<body class="min-h-screen bg-slate-50 text-slate-900 lg:h-screen lg:overflow-hidden">    <%- include('./partials/navbar') %>
    <main class="mx-auto w-full max-w-4xl px-4 py-7 lg:px-7">
        <header class="mb-7">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-indigo-600">Account</p>
            <h1 class="mt-2 text-3xl font-extrabold tracking-tight text-slate-900">My Profile</h1>
            <p class="mt-3 max-w-md text-xs leading-5 text-slate-600">
                View your account information and access your Evently activity.
            </p>
        </header>
        <section class="grid items-start gap-5 lg:grid-cols-[240px_1fr]">
            <aside class="overflow-hidden rounded-2xl bg-white shadow-lg ring-1 ring-slate-200">
                <div class="h-20 bg-linear-to-r from-indigo-600 via-violet-600 to-purple-600"></div>
                <div class="px-5 pb-5">
                    <div
                        class="-mt-9 flex h-20 w-20 items-center justify-center rounded-2xl border-4 border-white bg-indigo-100 text-3xl font-extrabold uppercase text-indigo-700 shadow-md">
                        <%= user.username.charAt(0) %>
                    </div>
                    <h2 class="mt-3 text-xl font-bold text-slate-900"><%= user.username %></h2>
                    <p class="mt-1 text-xs text-slate-500">Evently member</p>
                    <div class="mt-4 flex items-center gap-1.5 border-t border-slate-200 pt-4">
                        <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                        <span class="text-xs font-semibold text-emerald-700">Active account</span>
                    </div>
                </div>
            </aside>
            <div class="space-y-5">
                <section class="rounded-2xl bg-white p-5 shadow-lg ring-1 ring-slate-200 lg:p-5">
                    <div class="border-b border-slate-200 pb-3">
                        <h2 class="text-xl font-bold text-slate-900">Account Information</h2>
                        <p class="mt-1.5 text-xs text-slate-600">Your personal Evently account details.</p>
                    </div>
                    <div class="mt-5 grid gap-3 sm:grid-cols-2">
                        <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
                            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Username</p>
                            <p class="mt-1.5 text-xs font-bold text-slate-900"><%= user.username %></p>
                        </div>

                        <% if(user.email) { %>
                            <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
                                <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Email Address</p>
                                <p class="mt-1.5 break-all text-xs font-bold text-slate-900"><%= user.email %></p>
                            </div>
                        <% } %>
                            <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
                                <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Account Type</p>
                                <p class="mt-1.5 text-xs font-bold text-slate-900">Evently Member</p>
                            </div>

                        <% if(user.createdAt) { %>
                            <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
                                <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Member Since</p>
                                <p class="mt-1.5 text-xs font-bold text-slate-900">
                                    <%= user.createdAt.toLocaleDateString('en-GB') %>
                                </p>
                            </div>
                        <% } %>
                    </div>
                </section>
                <section class="rounded-2xl bg-white p-5 shadow-lg ring-1 ring-slate-200 lg:p-5">
                    <div class="border-b border-slate-200 pb-3">
                        <h2 class="text-xl font-bold text-slate-900">Quick Actions</h2>
                        <p class="mt-1.5 text-xs text-slate-600">
                            Quickly access the main areas of your account.
                        </p>
                    </div>

                    <div class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
                        <a href="/dashboard"
                            class="group rounded-xl border border-slate-200 bg-slate-50 p-3 transition duration-200 hover:-translate-y-0.5 hover:border-indigo-200 hover:bg-indigo-50 hover:shadow-md">
                            <div
                                class="flex h-8 w-8 items-center justify-center rounded-lg bg-indigo-100 text-base">📊
                            </div>
                            <h3 class="mt-3 text-sm font-bold text-slate-900 transition group-hover:text-indigo-700">
                                Dashboard
                            </h3>

                            <p class="mt-1.5 text-xs leading-4 text-slate-600"> View an overview of your events and participation.</p>
                        </a>
                        <a href="/events/new"
                            class="group rounded-xl border border-slate-200 bg-slate-50 p-3 transition duration-200 hover:-translate-y-0.5 hover:border-indigo-200 hover:bg-indigo-50 hover:shadow-md">
                            <div
                                class="flex h-8 w-8 items-center justify-center rounded-lg bg-indigo-100 text-base">➕
                            </div>
                            <h3 class="mt-3 text-sm font-bold text-slate-900 transition group-hover:text-indigo-700">Create Event</h3>
                            <p class="mt-1.5 text-xs leading-4 text-slate-600">Create and publish a new public or private event.</p>
                        </a>
                        <a href="/events"
                            class="group rounded-xl border border-slate-200 bg-slate-50 p-3 transition duration-200 hover:-translate-y-0.5 hover:border-indigo-200 hover:bg-indigo-50 hover:shadow-md">
                            <div
                                class="flex h-8 w-8 items-center justify-center rounded-lg bg-indigo-100 text-base">🔎
                            </div>

                            <h3 class="mt-3 text-sm font-bold text-slate-900 transition group-hover:text-indigo-700">Discover Events</h3>
                            <p class="mt-1.5 text-xs leading-4 text-slate-600">Browse and discover public events on Evently.</p>
                        </a>

                    </div>
                </section>
            </div>
        </section>
    </main>
</body>
</html>