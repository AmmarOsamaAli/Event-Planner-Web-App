<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="icon" type="image/svg+xml" href="/images/logos/icon.svg">
    <title>My Events</title>
</head>

<body class="min-h-screen bg-slate-50 text-slate-900">
    <%- include('../partials/navbar') %>

    <main class="mx-auto w-full max-w-4xl px-4 py-7 lg:px-7">
        <header class="mb-7">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-indigo-600">
                Event management
            </p>

            <h1 class="mt-2 text-3xl font-extrabold tracking-tight text-slate-900">
                My Events
            </h1>

            <p class="mt-3 max-w-md text-xs leading-5 text-slate-600">
                View, edit, and manage all the events you have created.
            </p>
        </header>

        <% if(events.length===0){ %>
            <section
                class="rounded-2xl border border-dashed border-slate-300 bg-white px-5 py-10 text-center shadow-sm">
                <div class="mx-auto flex h-10 w-10 items-center justify-center rounded-xl bg-indigo-100 text-xl">
                    📅
                </div>

                <h2 class="mt-4 text-base font-bold text-slate-900">
                    No events created yet
                </h2>

                <p class="mt-2 text-xs text-slate-600">
                    You have not created any event
                </p>
            </section>
        <% } %>

        <section class="space-y-4">
            <% for(let oneEvent of events) { %>
        
            <article
                class="grid overflow-hidden rounded-2xl bg-white shadow-lg ring-1 ring-slate-200 transition duration-200 hover:-translate-y-0.5 hover:shadow-xl lg:grid-cols-[15rem_1fr]">
            
                <div class="min-h-48 overflow-hidden bg-slate-200">
                    <img src="<%= oneEvent.image %>" alt="<%= oneEvent.title %>"
                        class="h-full w-full object-cover transition duration-300 hover:scale-105">
                </div>
            
                <div class="flex flex-col p-5 lg:p-5">
                    <a href="/events/<%= oneEvent._id %>" class="group">
                        <h2 class="text-xl font-bold text-slate-900 transition group-hover:text-indigo-600">
                            <%= oneEvent.title %>
                        </h2>
                    </a>
            
                    <p class="mt-3 line-clamp-3 text-xs leading-5 text-slate-600">
                        <%= oneEvent.description %>
                    </p>
            
                    <div class="mt-3 flex flex-wrap gap-1.5">
                        <% for(let category of oneEvent.categories) { %>
                            <span class="rounded-full bg-indigo-50 px-2 py-1 text-xs font-semibold text-indigo-700">
                                <%= category %>
                            </span>
                            <% } %>
                    </div>
            
                    <div class="mt-4 space-y-2 border-t border-slate-200 pt-3 text-xs text-slate-600">
                        <p>
                            <span class="font-semibold text-slate-800">Date:</span>
                            <%= oneEvent.date.toLocaleDateString('en-GB') + ", " + oneEvent.date.toLocaleTimeString() %>
                        </p>
            
                        <p>
                            <span class="font-semibold text-slate-800">Capacity:</span>
                            <%= oneEvent.capacity %>
                        </p>
                    </div>
            
                    <div class="mt-auto flex flex-wrap gap-2 pt-5">
                        <form method="get" action="/events/<%= oneEvent._id %>/edit">
                            <button type="submit"
                                class="cursor-pointer rounded-lg bg-indigo-600 px-4 py-2 text-xs font-semibold text-white shadow-sm transition duration-200 hover:bg-indigo-700 hover:shadow-md focus:outline-none focus:ring-3 focus:ring-indigo-200">
                                Edit Event
                            </button>
                        </form>
            
                        <form method="post" action="/events/<%= oneEvent._id %>?_method=DELETE">
                            <button type="submit"
                                class="cursor-pointer rounded-lg border border-red-200 bg-white px-4 py-2 text-xs font-semibold text-red-600 transition duration-200 hover:bg-red-50 focus:outline-none focus:ring-3 focus:ring-red-100">
                                Delete Event
                            </button>
                        </form>
                    </div>
                </div>
            
            </article>

            <% } %>
        </section>
    </main>
</body>

</html>