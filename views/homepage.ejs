<!DOCTYPE html>
<html lang="en" class="box-border">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

    <title>Homepage</title>
</head>

<body class="min-h-screen bg-slate-50 text-slate-900">
    <%- include('./partials/navbar') %>

        <main class="mx-auto flex min-h-[calc(100vh-73px)] max-w-7xl items-center px-6 py-12">
            <section class="w-full overflow-hidden rounded-3xl bg-white shadow-lg ring-1 ring-slate-200">
                <div class="grid items-center gap-10 px-8 py-14 lg:grid-cols-2 lg:px-14 lg:py-20">
                    <header>
                        <p class="mb-4 inline-block rounded-full bg-indigo-50 px-4 py-2 text-sm font-semibold text-indigo-600">
                            Discover events across Bahrain
                        </p>

                        <h1 class="max-w-2xl text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
                            Welcome to Evently
                        </h1>

                        <p class="mt-5 max-w-xl text-lg leading-8 text-slate-600">
                            Your One Stop To All Events in Bahrain
                        </p>

                        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
                            <form method="get" action="/events">
                                <button
                                    class="w-full rounded-xl bg-indigo-600 px-6 py-3 font-semibold text-white shadow-sm transition hover:bg-indigo-700 focus:outline-none focus:ring-4 focus:ring-indigo-200 sm:w-auto">
                                    See All Public Events
                                </button>
                            </form>

                            <form method="get" action="/events/new">
                                <button
                                    class="w-full rounded-xl border border-slate-300 bg-white px-6 py-3 font-semibold text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50 hover:text-indigo-700 focus:outline-none focus:ring-4 focus:ring-indigo-100 sm:w-auto">
                                    Create Your Own Event
                                </button>
                            </form>
                        </div>
                    </header>

                    <div class="relative hidden min-h-80 lg:block">
                        <div
                            class="absolute inset-0 rounded-3xl bg-linear-to-br from-indigo-500 via-violet-500 to-purple-600">
                        </div>

                        <div
                            class="absolute left-8 top-8 rounded-2xl border border-white/20 bg-white/15 p-6 text-white shadow-xl backdrop-blur-md">
                            <p class="text-sm font-medium text-white/80">
                                Explore
                            </p>

                            <h2 class="mt-2 text-2xl font-bold">
                                Public Events
                            </h2>

                            <p class="mt-3 max-w-xs text-sm leading-6 text-white/80">
                                Find experiences, gatherings, and activities happening around Bahrain.
                            </p>
                        </div>

                        <div
                            class="absolute bottom-8 right-8 rounded-2xl border border-white/20 bg-slate-950/20 p-6 text-white shadow-xl backdrop-blur-md">
                            <p class="text-3xl font-bold">
                                Evently
                            </p>

                            <p class="mt-1 text-sm text-white/80">
                                Create. Discover. Attend.
                            </p>
                        </div>
                    </div>

                </div>
            </section>
        </main>
</body>

</html>