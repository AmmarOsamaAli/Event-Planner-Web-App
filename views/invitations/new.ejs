<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

    <link rel="icon" type="image/svg+xml" href="/images/logos/icon.svg">

    <title>Send Invitation</title>
</head>

<body class="min-h-screen bg-slate-50 text-slate-900">
    <%- include('../partials/navbar') %>

    <main class="mx-auto w-full max-w-5xl px-6 py-10 lg:px-10">
        <header class="mb-8">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-indigo-600">Event participation</p>
            <h1 class="mt-3 text-5xl font-extrabold tracking-tight text-slate-900">Send Invitation</h1>
            <p class="mt-4 max-w-2xl text-lg leading-8 text-slate-600">Select a user and include a message with your invitation.</p>
        </header>

        <section class="overflow-hidden rounded-3xl bg-white shadow-xl ring-1 ring-slate-200">
            <form method="post" action="/events/<%= events._id %>/invitations" class="space-y-8 p-8 lg:p-10">

                <section class="rounded-2xl bg-slate-50 p-6 ring-1 ring-slate-200">
                    <div class="flex flex-col gap-5">
                        <div>
                            <p class="text-sm font-semibold uppercase tracking-wide text-indigo-600">Selected event</p>
                            <h2 class="mt-2 text-3xl font-bold text-slate-900"><%= events.title %></h2>
                        </div>

                        <p class="text-base leading-7 text-slate-600"><%= events.description %></p>
                        <div class="flex flex-wrap gap-2">
                            <% for(let category of events.categories) { %>
                                <span
                                    class="rounded-full bg-indigo-100 px-3 py-1.5 text-sm font-semibold text-indigo-700">
                                    <%= category %>
                                </span>
                            <% } %>
                        </div>

                        <div class="grid gap-5 border-t border-slate-200 pt-5 sm:grid-cols-2">
                            <div>
                                <p class="text-sm font-semibold uppercase tracking-wide text-slate-500">Location</p>
                                <p class="mt-1 font-semibold text-slate-900"><%= events.location %></p>
                            </div>

                            <div>
                                <p class="text-sm font-semibold uppercase tracking-wide text-slate-500">Date and Time</p>
                                <p class="mt-1 font-semibold text-slate-900">
                                    <%= events.date.toLocaleDateString('en-GB') + ", " +
                                        events.date.toLocaleTimeString() %>
                                </p>
                            </div>
                        </div>
                    </div>
                </section>

                <div>
                    <label for="participant" class="mb-2 block text-base font-semibold text-slate-700">
                        Who Do You Want To Invite?
                    </label>

                    <select required name="participant" id="participant"
                        class="w-full cursor-pointer rounded-xl border border-slate-300 bg-white px-4 py-3.5 text-base text-slate-900 outline-none transition focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100">
                        <% for(let oneUser of users) { %>
                            <option value="<%= oneUser._id %>">
                                <%= oneUser.username %>
                            </option>
                        <% } %>
                    </select>
                </div>

                <div>
                    <label for="message" class="mb-2 block text-base font-semibold text-slate-700">Invite Message</label>

                    <textarea id="message" name="message" maxlength="500" rows="6"
                        placeholder="Write a short invitation message..."
                        class="w-full resize-y rounded-xl border border-slate-300 bg-white px-4 py-3.5 text-base text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100"></textarea>

                    <p class="mt-2 text-sm text-slate-500">Maximum 500 characters.</p>
                </div>

                <div class="flex justify-end border-t border-slate-200 pt-8">
                    <button type="submit"
                        class="cursor-pointer rounded-xl bg-indigo-600 px-10 py-4 text-lg font-semibold text-white shadow-md transition duration-200 hover:bg-indigo-700 hover:shadow-lg focus:outline-none focus:ring-4 focus:ring-indigo-200">
                        Send Invitation
                    </button>
                </div>
            </form>
        </section>
    </main>
</body>
</html>