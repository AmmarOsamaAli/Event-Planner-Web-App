<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

    <link rel="icon" type="image/svg+xml" href="/images/logos/icon.svg">

    <title>Dashboard</title>
</head>

<body class="min-h-screen bg-slate-50 text-slate-900">
    <%- include('./partials/navbar') %>

    <main class="mx-auto w-full max-w-7xl px-8 py-10 lg:px-12">
        <header class="mb-10">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-indigo-600">
                Event management
            </p>

            <h1 class="mt-3 text-5xl font-extrabold tracking-tight text-slate-900">
                Dashboard
            </h1>

            <p class="mt-4 max-w-1xl text-lg leading-8 text-slate-600">
                Manage your events, attendance requests, invitations, and the events you are attending.
            </p>
        </header>

        <section class="grid gap-6 md:grid-cols-2">

            <article
                class="flex min-h-64 flex-col justify-between rounded-3xl bg-white p-8 shadow-lg ring-1 ring-slate-200 transition duration-200 hover:-translate-y-1 hover:shadow-xl">
                <div>
                    <div
                        class="flex h-14 w-14 items-center justify-center rounded-2xl bg-indigo-100 text-2xl font-bold text-indigo-600">
                        📅
                    </div>

                    <h2 class="mt-6 text-3xl font-bold text-slate-900">
                        My Events
                    </h2>

                    <p class="mt-3 text-base leading-7 text-slate-600">
                        View and manage all the events you have created.
                    </p>
                </div>

                <form method="get" action="/events/my-events" class="mt-8">
                    <button
                        class="w-full rounded-xl bg-indigo-600 px-6 py-4 text-lg font-semibold text-white shadow-md transition duration-200 hover:bg-indigo-700 hover:shadow-lg focus:outline-none focus:ring-4 focus:ring-indigo-200">
                        See My Events
                    </button>
                </form>
            </article>

            <article
                class="flex min-h-64 flex-col justify-between rounded-3xl bg-white p-8 shadow-lg ring-1 ring-slate-200 transition duration-200 hover:-translate-y-1 hover:shadow-xl">
                <div>
                    <div
                        class="flex h-14 w-14 items-center justify-center rounded-2xl bg-violet-100 text-2xl font-bold text-violet-600">
                        🎟️
                    </div>

                    <h2 class="mt-6 text-3xl font-bold text-slate-900">
                        Attending Events
                    </h2>

                    <p class="mt-3 text-base leading-7 text-slate-600">
                        View all the events you are currently attending.
                    </p>
                </div>

                <form method="get" action="/events/attending-events" class="mt-8">
                    <button
                        class="w-full rounded-xl bg-violet-600 px-6 py-4 text-lg font-semibold text-white shadow-md transition duration-200 hover:bg-violet-700 hover:shadow-lg focus:outline-none focus:ring-4 focus:ring-violet-200">
                        See Events I'm Attending
                    </button>
                </form>
            </article>

            <article
                class="flex min-h-64 flex-col justify-between rounded-3xl bg-white p-8 shadow-lg ring-1 ring-slate-200 transition duration-200 hover:-translate-y-1 hover:shadow-xl">
                <div>
                    <div
                        class="flex h-14 w-14 items-center justify-center rounded-2xl bg-amber-100 text-2xl font-bold text-amber-600">
                        🙋
                    </div>

                    <h2 class="mt-6 text-3xl font-bold text-slate-900">
                        Attendance Requests
                    </h2>

                    <p class="mt-3 text-base leading-7 text-slate-600">
                        Review requests received for your events and requests you have sent.
                    </p>
                </div>

                <form method="get" action="/events/attendance-requests" class="mt-8">
                    <button
                        class="w-full rounded-xl bg-amber-500 px-6 py-4 text-lg font-semibold text-white shadow-md transition duration-200 hover:bg-amber-600 hover:shadow-lg focus:outline-none focus:ring-4 focus:ring-amber-200">
                        See Attendance Requests
                    </button>
                </form>
            </article>

            <article
                class="flex min-h-64 flex-col justify-between rounded-3xl bg-white p-8 shadow-lg ring-1 ring-slate-200 transition duration-200 hover:-translate-y-1 hover:shadow-xl">
                <div>
                    <div
                        class="flex h-14 w-14 items-center justify-center rounded-2xl bg-emerald-100 text-2xl font-bold text-emerald-600">                       
                        ✉️
                    </div>

                    <h2 class="mt-6 text-3xl font-bold text-slate-900">
                        Invitations
                    </h2>

                    <p class="mt-3 text-base leading-7 text-slate-600">
                        View invitations you received and invitations you have sent.
                    </p>
                </div>

                <form method="get" action="/events/invitations" class="mt-8">
                    <button
                        class="w-full rounded-xl bg-emerald-600 px-6 py-4 text-lg font-semibold text-white shadow-md transition duration-200 hover:bg-emerald-700 hover:shadow-lg focus:outline-none focus:ring-4 focus:ring-emerald-200">
                        See Invitations
                    </button>
                </form>
            </article>

        </section>
    </main>
</body>

</html>