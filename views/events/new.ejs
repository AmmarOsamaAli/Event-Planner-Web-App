<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="icon" type="image/svg+xml" href="/images/logos/icon.svg">
    <title>Create Event</title>
</head>

<body class="min-h-screen bg-slate-50 text-slate-900">
    <%- include('../partials/navbar') %>

        <main class="mx-auto w-full max-w-3xl px-4 py-7 lg:px-7">
            <header class="mb-5">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-indigo-600">
                    Event management
                </p>

                <h1 class="mt-2 text-3xl font-extrabold tracking-tight text-slate-900">
                    Create Event
                </h1>

                <p class="mt-3 max-w-md text-xs leading-5 text-slate-600">
                    Add the event details below and publish it for people to discover.
                </p>
            </header>

            <section class="overflow-hidden rounded-2xl bg-white shadow-xl ring-1 ring-slate-200">
                <form method="post" action="/events" enctype="multipart/form-data" class="space-y-5 p-5 lg:p-7">

                    <section class="grid gap-4 lg:grid-cols-2">
                        <div class="lg:col-span-2">
                            <label for="title" class="mb-1.5 block text-xs font-semibold text-slate-700">
                                Title
                            </label>

                            <input required id="title" name="title" type="text" maxlength="100"
                                class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-xs text-slate-900 outline-none transition focus:border-indigo-500 focus:ring-3 focus:ring-indigo-100">
                        </div>

                        <div class="lg:col-span-2">
                            <label for="description" class="mb-1.5 block text-xs font-semibold text-slate-700">
                                Description
                            </label>

                            <textarea id="description" name="description" maxlength="1000" rows="3"
                                class="w-full resize-y rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-xs text-slate-900 outline-none transition focus:border-indigo-500 focus:ring-3 focus:ring-indigo-100"></textarea>
                        </div>

                        <div>
                            <label for="image" class="mb-1.5 block text-xs font-semibold text-slate-700">
                                Image
                            </label>

                            <input required id="image" name="image" type="file" accept="image/*"
                                class="block w-full cursor-pointer rounded-lg border border-slate-300 bg-white text-xs text-slate-600 file:mr-3 file:cursor-pointer file:border-0 file:bg-indigo-50 file:px-3.5 file:py-2.5 file:font-semibold file:text-indigo-700 hover:file:bg-indigo-100">
                        </div>

                        <div>
                            <label for="isPublic" class="mb-1.5 block text-xs font-semibold text-slate-700">
                                Is The Event Public?
                            </label>

                            <select required name="isPublic" id="isPublic"
                                class="w-full cursor-pointer rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-xs text-slate-900 outline-none transition focus:border-indigo-500 focus:ring-3 focus:ring-indigo-100">
                                <option value="true">Yes</option>
                                <option value="">No</option>
                            </select>
                        </div>
                    </section>

                    <fieldset class="rounded-xl border border-slate-200 bg-slate-50 p-4">
                        <legend class="px-1.5 text-xs font-bold text-slate-900">
                            Choose Appropriate Categories for Your Event
                        </legend>

                        <div class="mt-3 grid gap-2 sm:grid-cols-2 lg:grid-cols-3">

                            <label for="business"
                                class="flex cursor-pointer items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">
                                <input type="checkbox" name="categories" id="business" value="business"
                                    class="h-3.5 w-3.5 cursor-pointer accent-indigo-600">
                                💼 Business
                            </label>

                            <label for="technology"
                                class="flex cursor-pointer items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">
                                <input type="checkbox" name="categories" id="technology" value="technology"
                                    class="h-3.5 w-3.5 cursor-pointer accent-indigo-600">
                                💻 Technology
                            </label>

                            <label for="networking"
                                class="flex cursor-pointer items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">
                                <input type="checkbox" name="categories" id="networking" value="networking"
                                    class="h-3.5 w-3.5 cursor-pointer accent-indigo-600">
                                🤝 Networking
                            </label>

                            <label for="education"
                                class="flex cursor-pointer items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">
                                <input type="checkbox" name="categories" id="education" value="education"
                                    class="h-3.5 w-3.5 cursor-pointer accent-indigo-600">
                                🎓 Education
                            </label>

                            <label for="sports-fitness"
                                class="flex cursor-pointer items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">
                                <input type="checkbox" name="categories" id="sports-fitness" value="sports-fitness"
                                    class="h-3.5 w-3.5 cursor-pointer accent-indigo-600">
                                🏃 Sports & Fitness
                            </label>

                            <label for="social"
                                class="flex cursor-pointer items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">
                                <input type="checkbox" name="categories" id="social" value="social"
                                    class="h-3.5 w-3.5 cursor-pointer accent-indigo-600">
                                🎉 Social
                            </label>

                            <label for="music"
                                class="flex cursor-pointer items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">
                                <input type="checkbox" name="categories" id="music" value="music"
                                    class="h-3.5 w-3.5 cursor-pointer accent-indigo-600">
                                🎵 Music
                            </label>

                            <label for="arts-culture"
                                class="flex cursor-pointer items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">
                                <input type="checkbox" name="categories" id="arts-culture" value="arts-culture"
                                    class="h-3.5 w-3.5 cursor-pointer accent-indigo-600">
                                🎨 Arts & Culture
                            </label>

                            <label for="food-dining"
                                class="flex cursor-pointer items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">
                                <input type="checkbox" name="categories" id="food-dining" value="food-dining"
                                    class="h-3.5 w-3.5 cursor-pointer accent-indigo-600">
                                🍽️ Food & Dining
                            </label>

                            <label for="charity"
                                class="flex cursor-pointer items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">
                                <input type="checkbox" name="categories" id="charity" value="charity"
                                    class="h-3.5 w-3.5 cursor-pointer accent-indigo-600">
                                ❤️ Charity
                            </label>

                            <label for="family"
                                class="flex cursor-pointer items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">
                                <input type="checkbox" name="categories" id="family" value="family"
                                    class="h-3.5 w-3.5 cursor-pointer accent-indigo-600">
                                👨‍👩‍👧 Family
                            </label>

                            <label for="community"
                                class="flex cursor-pointer items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">
                                <input type="checkbox" name="categories" id="community" value="community"
                                    class="h-3.5 w-3.5 cursor-pointer accent-indigo-600">
                                🌍 Community
                            </label>

                        </div>
                    </fieldset>

                    <section class="grid gap-4 lg:grid-cols-3">
                        <div>
                            <label for="date" class="mb-1.5 block text-xs font-semibold text-slate-700">
                                Date / Time
                            </label>

                            <input required id="date" name="date" type="datetime-local"
                                class="w-full cursor-pointer rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-xs text-slate-900 outline-none transition focus:border-indigo-500 focus:ring-3 focus:ring-indigo-100">
                        </div>

                        <div>
                            <label for="location" class="mb-1.5 block text-xs font-semibold text-slate-700">
                                Location
                            </label>

                            <input required id="location" name="location" type="text"
                                class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-xs text-slate-900 outline-none transition focus:border-indigo-500 focus:ring-3 focus:ring-indigo-100">
                        </div>

                        <div>
                            <label for="capacity" class="mb-1.5 block text-xs font-semibold text-slate-700">
                                Maximum Attendees
                            </label>

                            <input required id="capacity" name="capacity" type="number" min="5" step="1"
                                class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-xs text-slate-900 outline-none transition focus:border-indigo-500 focus:ring-3 focus:ring-indigo-100">
                        </div>
                    </section>

                    <div class="flex justify-end border-t border-slate-200 pt-5">
                        <button type="submit"
                            class="cursor-pointer rounded-lg bg-indigo-600 px-7 py-2.5 text-xs font-semibold text-white shadow-md transition duration-200 hover:bg-indigo-700 hover:shadow-lg focus:outline-none focus:ring-3 focus:ring-indigo-200">
                            Create Event
                        </button>
                    </div>

                </form>
            </section>
        </main>
</body>

</html>