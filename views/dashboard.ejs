<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="icon" type="image/svg+xml" href="/images/logos/icon.svg">
    <title>Dashboard</title>
</head>

<body class="min-h-screen bg-slate-50 text-slate-900">
    <%- include('./partials/navbar') %>

    <main class="mx-auto w-full max-w-214.5 px-5.25 py-6.75 lg:px-8">
        <header class="mb-6.75">
            <p class="text-[9px] font-semibold uppercase tracking-[0.2em] text-indigo-600">
                Event management
            </p>

            <h1 class="mt-2 text-[32px] font-extrabold tracking-tight text-slate-900">
                Dashboard
            </h1>

            <p class="mt-2.75 max-w-1xl text-[12px] leading-5.25 text-slate-600">
                Manage your events, attendance requests, invitations, and the events you are attending.
            </p>
        </header>

        <section class="grid gap-4 md:grid-cols-2">

            <article
                class="flex min-h-43 flex-col justify-between rounded-2xl bg-white p-5.25 shadow-lg ring-1 ring-slate-200 transition duration-200 hover:-translate-y-0.75 hover:shadow-xl">
                <div>
                    <div
                        class="flex h-9.5 w-9.5 items-center justify-center rounded-[11px] bg-indigo-100 text-[16px]">
                        📅
                    </div>

                    <h2 class="mt-4 text-[20px] font-bold text-slate-900">
                        My Events
                    </h2>

                    <p class="mt-2 text-[11px] leading-4.75 text-slate-600">
                        View and manage all the events you have created.
                    </p>
                </div>

                <form method="get" action="/events/my-events" class="mt-5.25">
                    <button
                        class="cursor-pointer w-full rounded-lg bg-indigo-600 px-4 py-2.75 text-[12px] font-semibold text-white shadow-md transition duration-200 hover:bg-indigo-700 hover:shadow-lg focus:outline-none focus:ring-[3px] focus:ring-indigo-200">
                        See My Events
                    </button>
                </form>
            </article>

            <article
                class="flex min-h-43 flex-col justify-between rounded-2xl bg-white p-5.25 shadow-lg ring-1 ring-slate-200 transition duration-200 hover:-translate-y-0.75 hover:shadow-xl">
                <div>
                    <div
                        class="flex h-9.5 w-9.5 items-center justify-center rounded-[11px] bg-violet-100 text-[16px]">
                        🎟️
                    </div>

                    <h2 class="mt-4 text-[20px] font-bold text-slate-900">
                        Attending Events
                    </h2>

                    <p class="mt-2 text-[11px] leading-4.75 text-slate-600">
                        View all the events you are currently attending.
                    </p>
                </div>

                <form method="get" action="/events/attending-events" class="mt-5.25">
                    <button
                        class="cursor-pointer w-full rounded-lg bg-violet-600 px-4 py-2.75 text-[12px] font-semibold text-white shadow-md transition duration-200 hover:bg-violet-700 hover:shadow-lg focus:outline-none focus:ring-[3px] focus:ring-violet-200">
                        See Events I'm Attending
                    </button>
                </form>
            </article>

            <article
                class="flex min-h-43 flex-col justify-between rounded-2xl bg-white p-5.25 shadow-lg ring-1 ring-slate-200 transition duration-200 hover:-translate-y-0.75 hover:shadow-xl">
                <div>
                    <div
                        class="flex h-9.5 w-9.5 items-center justify-center rounded-[11px] bg-amber-100 text-[16px]">
                        🙋
                    </div>

                    <h2 class="mt-4 text-[20px] font-bold text-slate-900">
                        Attendance Requests
                    </h2>

                    <p class="mt-2 text-[11px] leading-4.75 text-slate-600">
                        Review requests received for your events and requests you have sent.
                    </p>
                </div>

                <form method="get" action="/events/attendance-requests" class="mt-5.25">
                    <button
                        class="cursor-pointer w-full rounded-lg bg-amber-500 px-4 py-2.75 text-[12px] font-semibold text-white shadow-md transition duration-200 hover:bg-amber-600 hover:shadow-lg focus:outline-none focus:ring-[3px] focus:ring-amber-200">
                        See Attendance Requests
                    </button>
                </form>
            </article>

            <article
                class="flex min-h-43 flex-col justify-between rounded-2xl bg-white p-5.25 shadow-lg ring-1 ring-slate-200 transition duration-200 hover:-translate-y-0.75 hover:shadow-xl">
                <div>
                    <div
                        class="flex h-9.5 w-9.5 items-center justify-center rounded-[11px] bg-emerald-100 text-[16px]">                       
                        ✉️
                    </div>

                    <h2 class="mt-4 text-[20px] font-bold text-slate-900">
                        Invitations
                    </h2>

                    <p class="mt-2 text-[11px] leading-4.75 text-slate-600">
                        View invitations you received and invitations you have sent.
                    </p>
                </div>

                <form method="get" action="/events/invitations" class="mt-5.25">
                    <button
                        class="cursor-pointer w-full rounded-lg bg-emerald-600 px-4 py-2.75 text-[12px] font-semibold text-white shadow-md transition duration-200 hover:bg-emerald-700 hover:shadow-lg focus:outline-none focus:ring-[3px] focus:ring-emerald-200">
                        See Invitations
                    </button>
                </form>
            </article>

        </section>
    </main>
</body>

</html>