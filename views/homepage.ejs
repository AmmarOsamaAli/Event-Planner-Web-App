<!DOCTYPE html>
<html lang="en" class="box-border">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Homepage</title>
</head>

<body class="min-h-screen bg-slate-50 text-slate-900 lg:h-screen lg:overflow-hidden">
    <%- include('./partials/navbar') %>
        <main class="mx-auto flex w-full max-w-375 items-center px-8 py-6 lg:h-[calc(100vh-5.5rem)] lg:px-12">
            <section class="w-full overflow-hidden rounded-3xl bg-white shadow-xl ring-1 ring-slate-200">
                <div class="grid min-h-140 items-center gap-14 px-12 py-14 lg:grid-cols-2 lg:px-18 lg:py-16">
                    <header>
                        <p
                            class="mb-6 inline-block rounded-full bg-indigo-50 px-5 py-2.5 text-base font-semibold text-indigo-600">
                            Discover events across Bahrain
                        </p>

                        <h1
                            class="max-w-2xl text-5xl font-extrabold leading-tight tracking-tight text-slate-900 lg:text-7xl">
                            Welcome to Evently
                        </h1>

                        <p class="mt-6 max-w-xl text-xl leading-8 text-slate-600">
                            Your One Stop To All Events in Bahrain
                        </p>

                        <div class="mt-10 flex flex-col gap-4 sm:flex-row">
                            <form method="get" action="/events">
                                <button
                                    class="w-full rounded-xl bg-indigo-600 px-8 py-4 text-lg font-semibold text-white shadow-md transition duration-200 hover:bg-indigo-700 hover:shadow-lg focus:outline-none focus:ring-4 focus:ring-indigo-200 sm:w-auto">
                                    See All Public Events
                                </button>
                            </form>

                            <form method="get" action="/events/new">
                                <button
                                    class="w-full rounded-xl border border-slate-300 bg-white px-8 py-4 text-lg font-semibold text-slate-700 transition duration-200 hover:border-indigo-300 hover:bg-indigo-50 hover:text-indigo-700 focus:outline-none focus:ring-4 focus:ring-indigo-100 sm:w-auto">
                                    Create Your Own Event
                                </button>
                            </form>
                        </div>
                    </header>

                    <div class="relative hidden min-h-110 lg:block">
                        <div
                            class="absolute inset-0 rounded-3xl bg-linear-to-br from-indigo-500 via-violet-500 to-purple-600">
                        </div>

                        <div
                            class="absolute left-10 top-10 w-[70%] rounded-2xl border border-white/20 bg-white/15 p-8 text-white shadow-xl backdrop-blur-md">
                            <p class="text-base font-medium text-white/80">
                                Explore
                            </p>

                            <h2 class="mt-3 text-3xl font-bold">
                                Public Events
                            </h2>

                            <p class="mt-4 max-w-sm text-base leading-7 text-white/80">
                                Find experiences, gatherings, and activities happening around Bahrain.
                            </p>
                        </div>

                        <div
                            class="absolute bottom-10 right-10 rounded-2xl border border-white/20 bg-slate-950/20 p-7 text-white shadow-xl backdrop-blur-md">
                            <p class="text-4xl font-bold">
                                Evently
                            </p>

                            <p class="mt-2 text-base text-white/80">
                                Create. Discover. Attend.
                            </p>
                        </div>
                    </div>

                </div>
            </section>
        </main>
</body>

</html>