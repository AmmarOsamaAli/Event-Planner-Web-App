<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="icon" type="image/svg+xml" href="/images/logos/icon.svg">
    <title>Edit Event</title>
</head>

<body class="min-h-screen bg-slate-50 text-slate-900">
    <%- include('../partials/navbar') %>

    <main class="mx-auto w-full max-w-6xl px-6 py-10 lg:px-10">
        <header class="mb-8">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-indigo-600">
                Event management
            </p>

            <h1 class="mt-3 text-5xl font-extrabold tracking-tight text-slate-900">
                Edit Event
            </h1>

            <p class="mt-4 max-w-2xl text-lg leading-8 text-slate-600">
                Update the event details below and save your changes.
            </p>
        </header>

        <section class="overflow-hidden rounded-3xl bg-white shadow-xl ring-1 ring-slate-200">
            <form method="post" action="/events/<%= events._id %>?_method=PUT" enctype="multipart/form-data"
                class="space-y-8 p-8 lg:p-10">

                <section class="grid gap-6 lg:grid-cols-2">
                    <div class="lg:col-span-2">
                        <label for="title" class="mb-2 block text-base font-semibold text-slate-700">
                            Title
                        </label>

                        <input value="<%= events.title %>" required id="title" name="title" type="text"
                            maxlength="100"
                            class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3.5 text-base text-slate-900 outline-none transition focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100">
                    </div>

                    <div class="lg:col-span-2">
                        <label for="description" class="mb-2 block text-base font-semibold text-slate-700">
                            Description
                        </label>

                        <textarea id="description" name="description" maxlength="1000" rows="5"
                            class="w-full resize-y rounded-xl border border-slate-300 bg-white px-4 py-3.5 text-base text-slate-900 outline-none transition focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100"><%= events.description %></textarea>
                    </div>

                    <div>
                        <label for="image" class="mb-2 block text-base font-semibold text-slate-700">
                            Image
                        </label>

                        <input id="image" name="image" type="file" accept="image/*"
                            class="block w-full cursor-pointer rounded-xl border border-slate-300 bg-white text-base text-slate-600 file:mr-4 file:cursor-pointer file:border-0 file:bg-indigo-50 file:px-5 file:py-3.5 file:font-semibold file:text-indigo-700 hover:file:bg-indigo-100">

                        <p class="mt-2 text-sm text-slate-500">
                            Leave this empty to keep the current image.
                        </p>
                    </div>

                    <div>
                        <label for="isPublic" class="mb-2 block text-base font-semibold text-slate-700">
                            Is The Event Public?
                        </label>

                        <select required name="isPublic" id="isPublic"
                            class="w-full cursor-pointer rounded-xl border border-slate-300 bg-white px-4 py-3.5 text-base text-slate-900 outline-none transition focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100">
                            <option value="true" <%=events.isPublic ? "selected" : "" %>
                                >
                                Yes
                            </option>

                            <option value="" <%=events.isPublic ? "" : "selected" %>
                                >
                                No
                            </option>
                        </select>
                    </div>
                </section>

                <fieldset class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
                    <legend class="px-2 text-lg font-bold text-slate-900">
                        Choose Appropriate Categories for Your Event
                    </legend>

                    <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">

                        <label for="business"
                            class="flex cursor-pointer items-center gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">
                            <input type="checkbox" name="categories" id="business" value="business"
                                <%=events.categories.includes("business") ? "checked" : "" %>
                            class="h-5 w-5 cursor-pointer accent-indigo-600"
                            >
                            💼 Business
                        </label>

                        <label for="technology"
                            class="flex cursor-pointer items-center gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">
                            <input type="checkbox" name="categories" id="technology" value="technology"
                                <%=events.categories.includes("technology") ? "checked" : "" %>
                            class="h-5 w-5 cursor-pointer accent-indigo-600"
                            >
                            💻 Technology
                        </label>

                        <label for="networking"
                            class="flex cursor-pointer items-center gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">
                            <input type="checkbox" name="categories" id="networking" value="networking"
                                <%=events.categories.includes("networking") ? "checked" : "" %>
                            class="h-5 w-5 cursor-pointer accent-indigo-600"
                            >
                            🤝 Networking
                        </label>

                        <label for="education"
                            class="flex cursor-pointer items-center gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">
                            <input type="checkbox" name="categories" id="education" value="education"
                                <%=events.categories.includes("education") ? "checked" : "" %>
                            class="h-5 w-5 cursor-pointer accent-indigo-600"
                            >
                            🎓 Education
                        </label>

                        <label for="sports-fitness"
                            class="flex cursor-pointer items-center gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">
                            <input type="checkbox" name="categories" id="sports-fitness" value="sports-fitness"
                                <%=events.categories.includes("sports-fitness") ? "checked" : "" %>
                            class="h-5 w-5 cursor-pointer accent-indigo-600"
                            >
                            🏃 Sports & Fitness
                        </label>

                        <label for="social"
                            class="flex cursor-pointer items-center gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">
                            <input type="checkbox" name="categories" id="social" value="social"
                                <%=events.categories.includes("social") ? "checked" : "" %>
                            class="h-5 w-5 cursor-pointer accent-indigo-600"
                            >
                            🎉 Social
                        </label>

                        <label for="music"
                            class="flex cursor-pointer items-center gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">
                            <input type="checkbox" name="categories" id="music" value="music"
                                <%=events.categories.includes("music") ? "checked" : "" %>
                            class="h-5 w-5 cursor-pointer accent-indigo-600"
                            >
                            🎵 Music
                        </label>

                        <label for="arts-culture"
                            class="flex cursor-pointer items-center gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">
                            <input type="checkbox" name="categories" id="arts-culture" value="arts-culture"
                                <%=events.categories.includes("arts-culture") ? "checked" : "" %>
                            class="h-5 w-5 cursor-pointer accent-indigo-600"
                            >
                            🎨 Arts & Culture
                        </label>

                        <label for="food-dining"
                            class="flex cursor-pointer items-center gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">
                            <input type="checkbox" name="categories" id="food-dining" value="food-dining"
                                <%=events.categories.includes("food-dining") ? "checked" : "" %>
                            class="h-5 w-5 cursor-pointer accent-indigo-600"
                            >
                            🍽️ Food & Dining
                        </label>

                        <label for="charity"
                            class="flex cursor-pointer items-center gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">
                            <input type="checkbox" name="categories" id="charity" value="charity"
                                <%=events.categories.includes("charity") ? "checked" : "" %>
                            class="h-5 w-5 cursor-pointer accent-indigo-600"
                            >
                            ❤️ Charity
                        </label>

                        <label for="family"
                            class="flex cursor-pointer items-center gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">
                            <input type="checkbox" name="categories" id="family" value="family"
                                <%=events.categories.includes("family") ? "checked" : "" %>
                            class="h-5 w-5 cursor-pointer accent-indigo-600"
                            >
                            👨‍👩‍👧 Family
                        </label>

                        <label for="community"
                            class="flex cursor-pointer items-center gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50">
                            <input type="checkbox" name="categories" id="community" value="community"
                                <%=events.categories.includes("community") ? "checked" : "" %>
                            class="h-5 w-5 cursor-pointer accent-indigo-600"
                            >
                            🌍 Community
                        </label>

                    </div>
                </fieldset>

                <section class="grid gap-6 lg:grid-cols-3">
                    <div>
                        <label for="date" class="mb-2 block text-base font-semibold text-slate-700">
                            Date / Time
                        </label>

                        <input value="<%= new Date(events.date.getTime() - events.date.getTimezoneOffset() * 60000).toISOString().slice(0, 16) %>" required id="date"
                            name="date" type="datetime-local"
                            class="w-full cursor-pointer rounded-xl border border-slate-300 bg-white px-4 py-3.5 text-base text-slate-900 outline-none transition focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100">
                    </div>

                    <div>
                        <label for="location" class="mb-2 block text-base font-semibold text-slate-700">
                            Location
                        </label>

                        <input value="<%= events.location %>" required id="location" name="location" type="text"
                            class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3.5 text-base text-slate-900 outline-none transition focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100">
                    </div>

                    <div>
                        <label for="capacity" class="mb-2 block text-base font-semibold text-slate-700">
                            Maximum Attendees
                        </label>

                        <input value="<%= events.capacity %>" required id="capacity" name="capacity" type="number"
                            min="5" step="1"
                            class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3.5 text-base text-slate-900 outline-none transition focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100">
                    </div>
                </section>

                <div class="flex justify-end border-t border-slate-200 pt-8">
                    <button type="submit"
                        class="cursor-pointer rounded-xl bg-indigo-600 px-10 py-4 text-lg font-semibold text-white shadow-md transition duration-200 hover:bg-indigo-700 hover:shadow-lg focus:outline-none focus:ring-4 focus:ring-indigo-200">
                        Update Event
                    </button>
                </div>
            </form>
        </section>
    </main>
</body>

</html>