<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="icon" type="image/svg+xml" href="/images/logos/icon.svg">
    <title>All Invitations</title>
</head>

<body class="min-h-screen bg-slate-50 text-slate-900">
    <%- include('../partials/navbar') %>
    <main class="mx-auto w-full max-w-4xl px-4 py-7 lg:px-7">
        <header class="mb-7">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-indigo-600">Event participation</p>
            <h1 class="mt-2 text-3xl font-extrabold tracking-tight text-slate-900">Invitations</h1>
            <p class="mt-3 max-w-md text-xs leading-5 text-slate-600">
                Review invitations you have received and track the invitations you have sent.
            </p>
        </header>

        <% const receivedInvitations=invitations.filter(oneInvitation=> {
            return (
            oneInvitation.event &&
            oneInvitation.event.eventPlanner &&
            oneInvitation.participant &&
            oneInvitation.participant._id.equals(user._id)
            )
        }) %>

        <% const sentInvitations=invitations.filter(oneInvitation=> {
            return (
            oneInvitation.event &&
            oneInvitation.event.eventPlanner &&
            oneInvitation.participant &&
            oneInvitation.event.eventPlanner._id.equals(user._id)
            )
        }) %>

        <section class="grid items-start gap-5 lg:grid-cols-2">
            <section class="rounded-2xl bg-white p-5 shadow-lg ring-1 ring-slate-200">
                <header class="flex items-center justify-between border-b border-slate-200 pb-3">
                    <div>
                        <h2 class="text-xl font-bold text-slate-900">Received Invitations</h2>
                        <p class="mt-1.5 text-xs text-slate-600">Invitations sent to you by event planners.</p>
                    </div>
                    <span
                        class="flex h-8 min-w-8 items-center justify-center rounded-full bg-indigo-100 px-2 text-xs font-bold text-indigo-700">
                        <%= receivedInvitations.length %>
                    </span>
                </header>

                <% if (receivedInvitations.length===0) { %>
                    <div class="py-9 text-center">
                        <div
                            class="mx-auto flex h-10 w-10 items-center justify-center rounded-xl bg-indigo-100 text-xl">📥
                        </div>

                        <h3 class="mt-3 text-sm font-bold text-slate-900">No received invitations</h3>
                        <p class="mt-1.5 text-xs text-slate-600">You have not received any invitations.</p>
                    </div>
                <% } else { %>

                    <div class="mt-4 space-y-3">
                        <% for(let oneInvitation of receivedInvitations) { %>
                            <article class="rounded-xl border border-slate-200 bg-slate-50 p-3">
                                <div class="flex flex-wrap items-start justify-between gap-2">
                                    <div>
                                        <p class="text-xs font-semibold uppercase tracking-wide text-indigo-600">Invitation to</p>
                                        <a href="/events/<%= oneInvitation.event._id %>" class="group">
                                            <h3
                                                class="mt-1 text-base font-bold text-slate-900 transition group-hover:text-indigo-600">
                                                <%= oneInvitation.event.title %>
                                            </h3>
                                        </a>
                                    </div>

                                    <span class="rounded-full px-2 py-1 text-xs font-semibold capitalize 
                                        <%= oneInvitation.status === 'accepted'
                                            ? 'bg-emerald-100 text-emerald-700'
                                            : oneInvitation.status === 'declined'
                                            ? 'bg-red-100 text-red-700'
                                            : oneInvitation.status === 'waitlisted'
                                            ? 'bg-amber-100 text-amber-700'
                                            : 'bg-indigo-100 text-indigo-700' %>">
                                        <%= oneInvitation.status %>
                                    </span>
                                </div>
                                <div class="mt-3 space-y-2 text-xs text-slate-600">
                                    <p>
                                        <span class="font-semibold text-slate-800">From:</span>
                                        <%= oneInvitation.event.eventPlanner.username %>
                                    </p>

                                    <div>
                                        <p class="font-semibold text-slate-800">Message:</p>
                                        <p class="mt-1 leading-5">
                                            <%= oneInvitation.message || "No message was included." %>
                                        </p>
                                    </div>
                                </div>

                                <% if( oneInvitation.status==="declined" ||
                                    oneInvitation.status==="waitlisted" ||
                                    oneInvitation.status==="pending" ) { %>

                                    <div class="mt-4 flex flex-wrap gap-2 border-t border-slate-200 pt-3">
                                        <% if(oneInvitation.status==="declined" ) { %>
                                            <form method="post"
                                                action="/invitations/<%= oneInvitation._id %>/accept?_method=PUT">
                                                <button type="submit"
                                                    class="cursor-pointer rounded-lg bg-emerald-600 px-3 py-2 font-semibold text-white shadow-sm transition hover:bg-emerald-700 focus:outline-none focus:ring-3 focus:ring-emerald-200">
                                                    Accept
                                                </button>
                                            </form>
                                        <% } %>
                                        <% if( oneInvitation.status==="waitlisted" ||
                                            oneInvitation.status==="pending" ) { %>
                                            <form method="post"
                                                action="/invitations/<%= oneInvitation._id %>/accept?_method=PUT">
                                                <button type="submit"
                                                    class="cursor-pointer rounded-lg bg-emerald-600 px-3 py-2 font-semibold text-white shadow-sm transition hover:bg-emerald-700 focus:outline-none focus:ring-3 focus:ring-emerald-200">
                                                    Accept
                                                </button>
                                            </form>

                                            <form method="post"
                                                action="/invitations/<%= oneInvitation._id %>/decline?_method=PUT">
                                                <button type="submit"
                                                    class="cursor-pointer rounded-lg border border-red-200 bg-white px-3 py-2 font-semibold text-red-600 transition hover:bg-red-50 focus:outline-none focus:ring-3 focus:ring-red-100">
                                                    Decline
                                                </button>
                                            </form>
                                        <% } %>
                                    </div>
                                <% } %>
                            </article>
                            <% } %>
                    </div>
                <% } %>
            </section>

            <section class="rounded-2xl bg-white p-5 shadow-lg ring-1 ring-slate-200">
                <header class="flex items-center justify-between border-b border-slate-200 pb-3">
                    <div>
                        <h2 class="text-xl font-bold text-slate-900">Sent Invitations</h2>
                        <p class="mt-1.5 text-xs text-slate-600">Invitations you sent for events you created.</p>
                    </div>
                    <span
                        class="flex h-8 min-w-8 items-center justify-center rounded-full bg-violet-100 px-2 text-xs font-bold text-violet-700">
                        <%= sentInvitations.length %>
                    </span>
                </header>

                <% if (sentInvitations.length===0) { %>
                    <div class="py-9 text-center">
                        <div class="mx-auto flex h-10 w-10 items-center justify-center rounded-xl bg-violet-100 text-xl">📤</div>
                        <h3 class="mt-3 text-sm font-bold text-slate-900">No sent invitations</h3>
                        <p class="mt-1.5 text-xs text-slate-600">You have not sent any invitations.</p>
                    </div>
                <% } else { %>
                    <div class="mt-4 space-y-3">
                        <% for(let oneInvitation of sentInvitations) { %>
                            <article class="rounded-xl border border-slate-200 bg-slate-50 p-3">
                                <div class="flex flex-wrap items-start justify-between gap-2">
                                    <div>
                                        <p class="text-xs font-semibold uppercase tracking-wide text-violet-600">
                                            Invitation sent for
                                        </p>

                                        <a href="/events/<%= oneInvitation.event._id %>" class="group">
                                            <h3
                                                class="mt-1 text-base font-bold text-slate-900 transition group-hover:text-indigo-600">
                                                <%= oneInvitation.event.title %>
                                            </h3>
                                        </a>
                                    </div>
                                    <span class="rounded-full px-2 py-1 text-xs font-semibold capitalize
                                        <%= oneInvitation.status === 'accepted'
                                            ? 'bg-emerald-100 text-emerald-700'
                                            : oneInvitation.status === 'declined'
                                            ? 'bg-red-100 text-red-700'
                                            : oneInvitation.status === 'waitlisted'
                                            ? 'bg-amber-100 text-amber-700'
                                            : 'bg-indigo-100 text-indigo-700' %>">
                                        <%= oneInvitation.status %>
                                    </span>
                                </div>

                                <div class="mt-3 space-y-2 text-xs text-slate-600">
                                    <p>
                                        <span class="font-semibold text-slate-800">Sent to:</span>
                                        <%= oneInvitation.participant.username %>
                                    </p>

                                    <div>
                                        <p class="font-semibold text-slate-800">Message:</p>

                                        <p class="mt-1 leading-5">
                                            <%= oneInvitation.message || "No message was included." %>
                                        </p>
                                    </div>
                                </div>

                                <% if( oneInvitation.status==="pending" ||
                                    oneInvitation.status==="waitlisted" ||
                                    oneInvitation.status==="declined" ) { %>
                                        <div class="mt-4 flex flex-wrap gap-2 border-t border-slate-200 pt-3">
                                            <% if( oneInvitation.status==="pending" || oneInvitation.status==="waitlisted" ) { %>
                                                <form method="post"
                                                    action="/invitations/<%= oneInvitation._id %>/cancel?_method=DELETE">
                                                    <button type="submit"
                                                        class="cursor-pointer rounded-lg border border-red-200 bg-white px-3 py-2 font-semibold text-red-600 transition hover:bg-red-50 focus:outline-none focus:ring-3 focus:ring-red-100">
                                                        Cancel Invitation
                                                    </button>
                                                </form>
                                            <% } %>

                                            <% if(oneInvitation.status==="declined" ) { %>
                                                <form method="get"
                                                    action="/events/<%= oneInvitation.event._id %>/invitations/new">
                                                    <button type="submit"
                                                        class="cursor-pointer rounded-lg bg-indigo-600 px-3 py-2 font-semibold text-white shadow-sm transition hover:bg-indigo-700 focus:outline-none focus:ring-3 focus:ring-indigo-200">
                                                        Send Invitation Again
                                                    </button>
                                                </form>
                                            <% } %>
                                        </div>
                                    <% } %>
                            </article>
                        <% } %>
                    </div>
                <% } %>
            </section>
        </section>
    </main>
</body>
</html>