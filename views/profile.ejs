<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

    <link rel="icon" type="image/svg+xml" href="/images/logos/icon.svg">

    <title>My Profile</title>
</head>

<body class="min-h-screen bg-slate-50 text-slate-900">
    <%- include('./partials/navbar') %>
    <main class="mx-auto w-full max-w-7xl px-6 py-10 lg:px-10">
        <header class="mb-10">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-indigo-600">Account</p>
            <h1 class="mt-3 text-5xl font-extrabold tracking-tight text-slate-900">My Profile</h1>
            <p class="mt-4 max-w-2xl text-lg leading-8 text-slate-600">
                View your account information and access your Evently activity.
            </p>
        </header>
        <section class="grid items-start gap-8 lg:grid-cols-[360px_1fr]">
            <aside class="overflow-hidden rounded-3xl bg-white shadow-lg ring-1 ring-slate-200">
                <div class="h-32 bg-linear-to-r from-indigo-600 via-violet-600 to-purple-600"></div>
                <div class="px-7 pb-8">
                    <div
                        class="-mt-14 flex h-28 w-28 items-center justify-center rounded-3xl border-8 border-white bg-indigo-100 text-5xl font-extrabold uppercase text-indigo-700 shadow-md">
                        <%= user.username.charAt(0) %>
                    </div>
                    <h2 class="mt-5 text-3xl font-bold text-slate-900"><%= user.username %></h2>
                    <p class="mt-1 text-base text-slate-500">Evently member</p>
                    <div class="mt-6 flex items-center gap-2 border-t border-slate-200 pt-6">
                        <span class="h-2.5 w-2.5 rounded-full bg-emerald-500"></span>
                        <span class="text-sm font-semibold text-emerald-700">Active account</span>
                    </div>
                </div>
            </aside>
            <div class="space-y-8">
                <section class="rounded-3xl bg-white p-7 shadow-lg ring-1 ring-slate-200 lg:p-8">
                    <div class="border-b border-slate-200 pb-5">
                        <h2 class="text-3xl font-bold text-slate-900">Account Information</h2>
                        <p class="mt-2 text-base text-slate-600">Your personal Evently account details.</p>
                    </div>
                    <div class="mt-7 grid gap-5 sm:grid-cols-2">
                        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
                            <p class="text-sm font-semibold uppercase tracking-wide text-slate-500">Username</p>
                            <p class="mt-2 text-lg font-bold text-slate-900"><%= user.username %></p>
                        </div>

                        <% if(user.email) { %>
                            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
                                <p class="text-sm font-semibold uppercase tracking-wide text-slate-500">Email Address</p>
                                <p class="mt-2 break-all text-lg font-bold text-slate-900"><%= user.email %></p>
                            </div>
                        <% } %>
                            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
                                <p class="text-sm font-semibold uppercase tracking-wide text-slate-500">Account Type</p>
                                <p class="mt-2 text-lg font-bold text-slate-900">Evently Member</p>
                            </div>

                        <% if(user.createdAt) { %>
                            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
                                <p class="text-sm font-semibold uppercase tracking-wide text-slate-500">Member Since</p>
                                <p class="mt-2 text-lg font-bold text-slate-900">
                                    <%= user.createdAt.toLocaleDateString('en-GB') %>
                                </p>
                            </div>
                        <% } %>
                    </div>
                </section>
                <section class="rounded-3xl bg-white p-7 shadow-lg ring-1 ring-slate-200 lg:p-8">
                    <div class="border-b border-slate-200 pb-5">
                        <h2 class="text-3xl font-bold text-slate-900">Quick Actions</h2>
                        <p class="mt-2 text-base text-slate-600">
                            Quickly access the main areas of your account.
                        </p>
                    </div>

                    <div class="mt-7 grid gap-5 sm:grid-cols-2 xl:grid-cols-3">
                        <a href="/dashboard"
                            class="group rounded-2xl border border-slate-200 bg-slate-50 p-5 transition duration-200 hover:-translate-y-1 hover:border-indigo-200 hover:bg-indigo-50 hover:shadow-md">
                            <div
                                class="flex h-12 w-12 items-center justify-center rounded-xl bg-indigo-100 text-2xl">📊
                            </div>
                            <h3 class="mt-5 text-xl font-bold text-slate-900 transition group-hover:text-indigo-700">
                                Dashboard
                            </h3>

                            <p class="mt-2 leading-6 text-slate-600"> View an overview of your events and participation.</p>
                        </a>
                        <a href="/events/new"
                            class="group rounded-2xl border border-slate-200 bg-slate-50 p-5 transition duration-200 hover:-translate-y-1 hover:border-indigo-200 hover:bg-indigo-50 hover:shadow-md">
                            <div
                                class="flex h-12 w-12 items-center justify-center rounded-xl bg-indigo-100 text-2xl">➕
                            </div>
                            <h3 class="mt-5 text-xl font-bold text-slate-900 transition group-hover:text-indigo-700">Create Event</h3>
                            <p class="mt-2 leading-6 text-slate-600">Create and publish a new public or private event.</p>
                        </a>
                        <a href="/events"
                            class="group rounded-2xl border border-slate-200 bg-slate-50 p-5 transition duration-200 hover:-translate-y-1 hover:border-indigo-200 hover:bg-indigo-50 hover:shadow-md">
                            <div
                                class="flex h-12 w-12 items-center justify-center rounded-xl bg-indigo-100 text-2xl">🔎
                            </div>

                            <h3 class="mt-5 text-xl font-bold text-slate-900 transition group-hover:text-indigo-700">Discover Events</h3>
                            <p class="mt-2 leading-6 text-slate-600">Browse and discover public events on Evently.</p>
                        </a>

                    </div>
                </section>
            </div>
        </section>
    </main>
</body>
</html>